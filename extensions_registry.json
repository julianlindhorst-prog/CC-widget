{
  "widgets": [
    {
      "title": "Welcome Banner",
      "type": "demo_welcome_banner",
      "category": "custom",
      "source": {
        "path": "widgets/community-stats",
        "entry": "index.html"
      },
      "configuration": {
        "properties": [
          {
            "name": "headline",
            "type": "text",
            "label": "Headline",
            "defaultValue": "Welcome to the Community",
            "rules": { "required": true, "maxLength": 80 }
          },
          {
            "name": "subtext",
            "type": "text",
            "label": "Subtext",
            "defaultValue": "Ask questions and connect with peers.",
            "rules": { "maxLength": 160 }
          },
          {
            "name": "button_label",
            "type": "text",
            "label": "Button Label",
            "defaultValue": "Get Started"
          },
          {
            "name": "button_url",
            "type": "text",
            "label": "Button URL",
            "defaultValue": "#"
          }
        ]
      },
      "defaultConfig": {
        "headline": "Welcome to the Community",
        "subtext": "Ask questions and connect with peers.",
        "button_label": "Get Started",
        "button_url": "#"
      }
    },
    {
      "title": "Countries HTML",
      "type": "demo_countries_html",
      "category": "custom",
      "source": {
        "path": "widgets/countries-html/dist",
        "entry": "content.html"
      }
    },
    {
      "title": "Countries Vanilla",
      "type": "demo_countries_vanilla",
      "category": "custom",
      "source": {
        "path": "widgets/countries-vanilla/dist",
        "entry": "index.html"
      }
    },
    {
      "version": "1.0.0",
      "title": "Cross-Language Content",
      "type": "personio_cross_language_content",
      "description": "Shows recent topics from a configurable set of categories or groups, regardless of their community language.",
      "category": "custom",
      "containers": ["Full width", "Sidebar"],
      "widgetsLibrary": true,
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": true
      },
      "source": {
        "path": "widgets/cross_language_widget",
        "entry": "index.html"
      },
      "configuration": {
        "properties": [
          { "name": "heading", "type": "text", "label": "Section heading", "defaultValue": "Related content" },
          { "name": "ctaLabel", "type": "text", "label": "CTA button label", "defaultValue": "See all" },
          { "name": "ctaUrl", "type": "text", "label": "CTA URL", "defaultValue": "https://community.personio.de" },
          { "name": "connectors", "type": "text", "label": "Connector permalinks (comma-separated)", "defaultValue": "personio-cc-topics-de-cat-163" },
          { "name": "limit", "type": "text", "label": "Max topics to show", "defaultValue": "10" },
          { "name": "sort", "type": "text", "label": "Sort field", "defaultValue": "lastActivityAt" },
          { "name": "communityUrl", "type": "text", "label": "Community base URL", "defaultValue": "https://julian-en-community.insided.com" }
        ]
      }
    }
  ]
}
